rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidReactionMap(data) {
      return data is map
        && data.keys().hasOnly(['angry', 'laugh', 'like'])
        && data.keys().hasAll(['angry', 'laugh', 'like'])
        && data.angry is int && data.angry >= 0
        && data.laugh is int && data.laugh >= 0
        && data.like is int && data.like >= 0;
    }

    function isRecentClientTime(createdAtMs) {
      return createdAtMs is int
        && createdAtMs > request.time.toMillis() - 60 * 60 * 1000
        && createdAtMs < request.time.toMillis() + 5 * 60 * 1000;
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly(['reactions', 'updatedAt'])
        && (!('reactions' in request.resource.data) || isValidReactionMap(request.resource.data.reactions));
      allow delete: if false;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasOnly(['author', 'text', 'createdAt', 'createdAtMs'])
          && request.resource.data.author is string
          && request.resource.data.author.size() > 0
          && request.resource.data.author.size() <= 60
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && isRecentClientTime(request.resource.data.createdAtMs);
        allow update, delete: if false;
      }
    }

    match /contactSubmissions/{submissionId} {
      allow read: if false;
      allow create: if request.resource.data.keys().hasOnly(['name', 'topic', 'message', 'source', 'createdAt', 'createdAtMs'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.topic is string
        && request.resource.data.topic.size() > 0
        && request.resource.data.topic.size() <= 140
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 3000
        && request.resource.data.source == 'kontakt'
        && isRecentClientTime(request.resource.data.createdAtMs);
      allow update, delete: if false;
    }
  }
}
